{
    "enabled": "true",
    "increase-coverage": {
      "project-name": "dotnet-grandnode",
      "target-branches": [
        "main",
        "master",
        "develop"
      ],
      "test-env-docker-stage": "test",
      "build-test-env-docker-stage-script-path": "tool/build-test-env-docker-stage.sh",
      "test-files-folders": [
        "Tests/Grand.Core.Tests/CommonHelperTests.cs"
      ],
      "source-test-file-paths": [
        {
          "source-file-path": "Grand.Core/CommonHelper.cs",
          "test-file-path": "Tests/Grand.Core.Tests/CommonHelperTests.cs"
        }
      ],
      "test-command": "dotnet test --collect:\"XPlat Code Coverage\" --results-directory ./Tests/TestResults && find ./Tests/TestResults -name \"coverage.cobertura.xml\" -exec cp {} ./Tests/TestResults/coverage.cobertura.xml \\;'",
      "coverage-type": "cobertura",
      "code-coverage-report-path": "Tests/TestResults/coverage.cobertura.xml",
      "desired-coverage": 80,
      "max-iterations": 3,
      "max-number-of-test-cases": 8
      }
  }
